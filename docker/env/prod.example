COMPOSE_PROJECT_NAME=prod
PLATFORM=linux/amd64

# Public ports.
HOST_PORT=3000
AI_SERVICE_FORWARD_PORT=5555
POSTGRES_FORWARD_PORT=9432
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
IBIS_SERVER_PORT=8000
WREN_AI_SERVICE_PORT=5555
TRINO_FORWARD_PORT=8081
TRINO_CATALOG_MANAGEMENT=dynamic

# Internal service URLs used by containers.
PG_URL=postgres://postgres:postgres@postgres:5432/wrenai
PG_CONN_STR=postgresql://postgres:postgres@postgres:5432/wrenai

# Database defaults. For production, prefer replacing PG_URL/PG_CONN_STR with a managed PostgreSQL endpoint.
POSTGRES_DB=wrenai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Image versions.
WREN_PRODUCT_VERSION=local
WREN_ENGINE_VERSION=local
WREN_AI_SERVICE_VERSION=0.29.0
WREN_UI_VERSION=0.32.2
IBIS_SERVER_VERSION=local
TRINO_VERSION=475
WREN_ENGINE_IMAGE_REPO=engine
WREN_ENGINE_IMAGE_TAG=local
IBIS_SERVER_IMAGE_REPO=engine-ibis
IBIS_SERVER_IMAGE_TAG=local
IBIS_SERVER_BUILD_ENV=prod
LOCAL_STORAGE=./data

# AI service config/secrets.
AI_SERVICE_ENV_FILE=./env/prod.example
AI_CONFIG_FILE=./config/ai.config.example.yaml
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
EMBEDDING_MODEL_DIMENSION=4096
GENERATION_MODEL=openrouter/deepseek/deepseek-v4-flash

# UI runtime / telemetry.
USER_UUID=
POSTHOG_API_KEY=
POSTHOG_HOST=
TELEMETRY_ENABLED=false
EXPERIMENTAL_ENGINE_RUST_VERSION=false
TRINO_RUNTIME_USER=wrenai
TRINO_RUNTIME_PASSWORD=
TRINO_RUNTIME_SSL=false
BACKGROUND_TRACKER_WORKSPACE_ID=
